<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= site.title %></title>
    <meta name="description" content="<%= site.tagline %>" />
    <% if (assets.logo) { %>
    <link rel="icon" href="<%= assets.logo %>" type="image/jpeg" />
    <% } %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/public/styles.css" />
    <link rel="stylesheet" href="/public/proposal.css" />
    <% if (assets.heroBg) { %>
    <style>
      :root {
        <% if (assets.heroBg) { %>--asset-hero-bg: url('<%= assets.heroBg %>');<% } %>
        <% if (assets.mapBg) { %>--asset-map-bg: url('<%= assets.mapBg %>');<% } %>
        <% if (assets.conclusionBg) { %>--asset-conclusion-bg: url('<%= assets.conclusionBg %>');<% } %>
        <% if (assets.panelOne) { %>--asset-panel-one: url('<%= assets.panelOne %>');<% } %>
        <% if (assets.panelTwo) { %>--asset-panel-two: url('<%= assets.panelTwo %>');<% } %>
        <% if (assets.panelThree) { %>--asset-panel-three: url('<%= assets.panelThree %>');<% } %>
      }
    </style>
    <% } %>
  </head>
  <body>
    <div class="grain"></div>
    <div class="orb orb-one"></div>
    <div class="orb orb-two"></div>

    <header class="topbar">
      <div class="container d-flex justify-content-between align-items-center py-3">
        <div>
          <div class="brand-mark">GDBIT</div>
          <div class="brand-sub">Green Defence Bamboo Initiative Tanzania</div>
        </div>
        <nav class="topnav d-none d-lg-flex gap-3 flex-wrap justify-content-end">
          <a href="#proposal-hero">Summary</a>
          <a href="#team">Team</a>
          <a href="#vision-mission">Vision</a>
          <a href="#strategic-objectives">Objectives</a>
          <a href="#partnership-structure">Partnership</a>
          <a href="#value-chain">Value Chain</a>
          <a href="#plantation-strategy">Plantation</a>
          <a href="#manufacturing">Manufacturing</a>
          <a href="#military-products">Military</a>
          <a href="#commercial-products">Commercial</a>
          <a href="#environmental-impact">Impact</a>
          <a href="#investment">Investment</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="proposal-document">
      <%- include('partials/proposal-sections') %>

      <section id="contact" class="section-pad contact-section proposal-section" data-slide="Contact">
        <div class="container">
          <div class="row g-4 align-items-center">
            <div class="col-lg-5 reveal">
              <span class="eyebrow">Contact</span>
              <h2>Start a conversation about bamboo, investment, or collaboration</h2>
              <p>Reach the GDBIT partnership team to discuss investment, procurement, or strategic collaboration.</p>
            </div>
            <div class="col-lg-7 reveal">
              <form class="contact-form">
                <div class="row g-3">
                  <div class="col-md-6"><input type="text" class="form-control" placeholder="Your name" /></div>
                  <div class="col-md-6"><input type="text" class="form-control" placeholder="Organisation" /></div>
                  <div class="col-md-6"><input type="email" class="form-control" placeholder="Email address" /></div>
                  <div class="col-md-6"><input type="text" class="form-control" placeholder="Interest area" /></div>
                  <div class="col-12"><textarea class="form-control" rows="5" placeholder="Tell us how you want to connect."></textarea></div>
                  <div class="col-12">
                    <button class="btn btn-emerald btn-lg" type="button">Send Message</button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer" aria-label="Site footer">
      <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 py-4">
        <div class="footer-brand d-flex align-items-center gap-3">
          <% if (assets.logo) { %>
            <img class="footer-logo" src="<%= assets.logo %>" alt="Company logo" />
          <% } %>
          <div>
            <div class="footer-title">Green Defence Bamboo Initiative Tanzania</div>
            <div class="footer-subtitle">UNLOCK GROUP LIMITED × JWAPANO Bamboo Tanzania</div>
          </div>
        </div>
        <div class="footer-note text-md-end">
          Sustainable bamboo development, production, and partnership planning.
        </div>
      </div>
    </footer>

    <aside class="proposal-toolbar" aria-label="Proposal tools">
      <div class="toolbar-group">
        <button type="button" id="btn-presentation" title="Presentation mode">Present</button>
        <button type="button" data-export="pdf" title="Export PDF">PDF</button>
        <button type="button" data-export="docx" title="Export Word">Word</button>
        <button type="button" data-export="pptx" title="Export PowerPoint">PPT</button>
        <a href="/admin" title="Admin dashboard">Admin</a>
      </div>
    </aside>

    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
      <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
      <img src="" alt="" />
    </div>

    <div id="presentation-mode" class="presentation-mode" aria-hidden="true">
      <div class="presentation-slides"></div>
      <div class="presentation-controls">
        <button type="button" class="presentation-close btn btn-sm btn-outline-light">Exit</button>
        <button type="button" class="presentation-prev btn btn-sm btn-outline-light">← Prev</button>
        <div class="presentation-progress"><span style="width:0%"></span></div>
        <span class="presentation-counter text-secondary small">1 / 1</span>
        <button type="button" class="presentation-next btn btn-sm btn-outline-light">Next →</button>
        <button type="button" class="presentation-autoplay btn btn-sm btn-emerald">Auto-play</button>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="/public/app.js"></script>
    <script src="/public/proposal.js"></script>
    <script src="/public/presentation.js"></script>
  </body>
</html>
